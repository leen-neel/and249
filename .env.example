APP_URL="MY_APP_URL"

# Contact form — Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
# Dev test keys (always pass): site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY="YOUR_TURNSTILE_SITE_KEY"
TURNSTILE_SECRET_KEY="YOUR_TURNSTILE_SECRET_KEY"

# Contact form — Telegram bot notifications
# Create bot via @BotFather, message it, then GET https://api.telegram.org/bot<TOKEN>/getUpdates for chat_id
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"

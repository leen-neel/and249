---
import Layout from "../layouts/Layout.astro";

import Skill from "../components/Skill.astro";
import Socials from "../components/Socials.astro";

import "../assets/styles.scss";

import skills from "../data/skills.json";
import socials from "../data/socials.json";
---

<Layout title="Welcome to Astro.">
  <main>
    <section class="hero flex items-center md:min-h-screen h-[80vh]">
      <div class="container mx-auto px-4">
        <div class="flex flex-wrap items-center">
          <div class="w-full lg:w-1/2 px-4 hero-text">
            <h2 class="">Greetings!</h2>
            <h2 class="">
              I'm <span
                class="font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-cyan-500"
                >Neel</span
              >
            </h2>

            <div>
              <ul class="flex gap-3">
                {
                  socials.map((social) => (
                    <Socials link={social.link} icon={social.icon} />
                  ))
                }
              </ul>
            </div>
          </div>

          <div class="w-full lg:w-1/2 place-content-center grid">
            <img
              src="Myself.jpeg"
              alt="Hero Image"
              class="max-w-xs md:max-w-sm md:rounded-full rounded-lg shadow-2xl md:mt-0 mt-10"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="md:px-[10rem] p-5 md:p-0">
      <ul class="grid grid-cols-2 gap-4 sm:grid-cols-2">
        {skills.map((skill) => <Skill name={skill.name} icon={skill.icon} />)}
      </ul>
    </section>
  </main>

  <style lang="scss">
    .hero-text {
      font-size: 6rem;
    }

    .hero-img {
      border-radius: 50%;
    }

    // make the class above responsive
    @media (max-width: 768px) {
      .hero-text {
        font-size: 4rem;
      }
    }
  </style>
</Layout>

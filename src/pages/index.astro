---
import Layout from "layouts/Layout.astro";

import Skill from "components/Skill.astro";
import skills from "data/skills.json";
import Card from "components/Card.astro";

import "~/assets/styles.scss";

import Hero from "sections/Hero.astro";
---

<Layout title="Welcome to Astro.">
  <main>
    <Hero />

    <div class="md:px-[10rem] p-5 md:p-0 md:mb-10 text-xl z-30">
      <p>
        Hey there! I am Anindo Neel Dutta! I hail from 🇮🇳. I am a full-stack web
        developer who builds projects on the MEVN stack.
      </p>

      <p class="mt-3">
        I've been coding since the age of 6. Programming has been an essential
        part of my life. Learning about new technology and building apps that
        find solutions to make life easier has always been a passion of mine.
      </p>
    </div>

    <section class="md:px-[10rem] p-5 md:p-0">
      <h2 class="group text-2xl md:text-5xl font-bold mb-4">
        Technolgies I love
      </h2>

      <ul class="grid grid-cols-2 gap-4 sm:grid-cols-2">
        {skills.map((skill) => <Skill name={skill.name} icon={skill.icon} />)}
      </ul>
    </section>

    <section class="md:px-[10rem] p-5">
      <h2 class="group text-2xl md:text-5xl font-bold mb-4">Projects</h2>

      <div class="grid grid-cols-4">
        <Card
          title="Lore"
          badges={["sex", "sex 2"]}
          image="https://danidiaztech.com/assets/URL-shortener.8e51537b_11HvW1.avif"
          description="lorem"
        />
        <Card
          title="Lore"
          badges={["sex", "sex 2"]}
          image="https://danidiaztech.com/assets/URL-shortener.8e51537b_11HvW1.avif"
          description="lorem"
        />
        <Card
          title="Lore"
          badges={["sex", "sex 2"]}
          image="https://danidiaztech.com/assets/URL-shortener.8e51537b_11HvW1.avif"
          description="lorem"
        />
        <Card
          title="Lore"
          badges={["sex", "sex 2"]}
          image="https://danidiaztech.com/assets/URL-shortener.8e51537b_11HvW1.avif"
          description="lorem"
        />
      </div>
    </section>
  </main>
</Layout>

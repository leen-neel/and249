---
import Layout from "../layouts/Layout.astro";

import Skill from "../components/Skill.astro";
import Socials from "../components/Socials.astro";

import "../assets/styles.scss";

import skills from "../data/skills.json";
import socials from "../data/socials.json";
---

<Layout title="Welcome to Astro.">
  <main>
    <section class="hero flex items-center md:min-h-screen h-[80vh]">
      <div class="container mx-auto px-4">
        <div class="flex flex-wrap items-center">
          <div class="w-full lg:w-1/2 px-4 hero-text">
            <h2 class="">Greetings!</h2>
            <h2 class="">
              I'm <span
                class="font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-cyan-500"
                >Neel</span
              >
            </h2>

            <div>
              <ul class="flex gap-3">
                {
                  socials.map((social) => (
                    <Socials link={social.link} icon={social.icon} />
                  ))
                }
              </ul>
            </div>
          </div>

          <div class="w-full lg:w-1/2 place-content-center grid relative">
            <div
              class="absolute top-0 left-0 aspect-square w-72 h-72 lg:w-96 lg:h-96 rounded-full bg-gradient-to-tr from-indigo-700 filter blur-xl opacity-80 dark:opacity-50 animate-blob animation-delay-2000"
            >
            </div>
            <div
              class="absolute right-52 top-52 aspect-square w-72 h-72 lg:w-96 lg:h-96 rounded-full bg-gradient-to-tr from-red-700 filter blur-xl opacity-80 dark:opacity-50 animate-blob animation-delay-2000"
            >
            </div>
            <div
              class="absolute bottom-0 right-0 aspect-square w-72 h-72 lg:w-96 lg:h-96 rounded-full bg-gradient-to-b from-emerald-500 filter blur-xl opacity-80 dark:opacity-50 animate-blob animation-delay-4000"
            >
            </div>

            <img
              src="Myself.jpeg"
              alt="Hero Image"
              class="z-10 max-w-xs md:max-w-sm md:rounded-full rounded-lg shadow-2xl md:mt-0 mt-10 border-0 md:border-t-2 md:border-b-2 border-cyan-500"
            />
          </div>
        </div>
      </div>
    </section>

    <div class="md:px-[10rem] p-5 md:p-0 md:mb-10 text-xl">
      <p>
        Hey there! I am Anindo Neel Dutta! I hail from 🇮🇳. I am a full-stack web
        developer who builds projects on the MEVN stack.
      </p>

      <p class="mt-3">
        I've been coding since the age of 6. Programming has been an essential
        part of my life. Learning about new technology and building apps that
        find solutions to make life easier has always been a passion of mine.
      </p>
    </div>

    <section class="md:px-[10rem] p-5 md:p-0">
      <ul class="grid grid-cols-2 gap-4 sm:grid-cols-2">
        {skills.map((skill) => <Skill name={skill.name} icon={skill.icon} />)}
      </ul>
    </section>
  </main>

  <style lang="scss">
    .hero-text {
      font-size: 6rem;
    }

    .hero-img {
      border-radius: 50%;
    }

    // make the class above responsive
    @media (max-width: 768px) {
      .hero-text {
        font-size: 4rem;
      }
    }

    // make me an animation where the blob moves around
    @keyframes blob {
      0% {
        transform: translate(0px, 0px) scale(1);
      }
      33% {
        transform: translate(30px, -50px) scale(1.1);
      }
      66% {
        transform: translate(-20px, 20px) scale(0.9);
      }
      100% {
        transform: translate(0px, 0px) scale(1);
      }
    }

    // now implement it in a class
    .animate-blob {
      animation: blob 10s infinite;
    }
  </style>
</Layout>

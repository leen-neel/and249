---
import { Icon } from "astro-icon/components";

export interface Props {
  name: string;
  icon: string;
}

const { icon, name } = Astro.props;
---

<li class="flex items-center gap-4">
  <span
    class="w-11 h-11 flex items-center justify-center border-t border-zinc-700 border-transparent shadow-none bg-slate-900 rounded-full"
  >
    <Icon name={icon} class="w-6" />
  </span>
  <span class="text-xl font-bold">{name}</span>
</li>

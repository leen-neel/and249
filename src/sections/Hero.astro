---
import socials from "data/socials.json";
import Socials from "components/Socials.astro";
---

<section class="hero flex items-center md:min-h-screen h-[80vh]">
  <div class="container mx-auto px-4">
    <div class="flex flex-wrap items-center">
      <div class="w-full ubuntu lg:w-1/2 px-4 hero-text">
        <h2 class="mb-[-1.5rem]">Greetings!</h2>
        <h2 class="group">
          I'm <span
            id="name"
            class="font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-cyan-500"
          >
            Neel
          </span>
        </h2>

        <div>
          <ul class="flex gap-3">
            {
              socials.map((social) => (
                <Socials
                  link={social.link}
                  icon={social.icon}
                  name={social.name}
                />
              ))
            }
          </ul>
        </div>
      </div>

      <div class="w-full lg:w-1/2 place-content-center grid relative">
        <div
          class="invisible md:visible absolute right-52 bottom-52 aspect-square w-72 h-72 lg:w-96 lg:h-96 rounded-full bg-gradient-to-r from-cyan-500 filter blur-xl opacity-80 dark:opacity-50 animate-blob animation-delay-2000"
        >
        </div>
        <div
          class="absolute top-0 left-0 aspect-square w-72 h-72 lg:w-96 lg:h-96 rounded-full bg-gradient-to-tr from-indigo-700 filter blur-xl opacity-80 dark:opacity-50 animate-blob2 animation-delay-2000"
        >
        </div>
        <div
          class="absolute right-52 top-52 aspect-square w-72 h-72 lg:w-96 lg:h-96 rounded-full bg-gradient-to-tr from-red-700 filter blur-xl opacity-80 dark:opacity-50 animate-blob3 animation-delay-2000"
        >
        </div>
        <div
          class="absolute bottom-0 right-0 aspect-square w-72 h-72 lg:w-96 lg:h-96 rounded-full bg-gradient-to-b from-emerald-500 filter blur-xl opacity-80 dark:opacity-50 animate-blob4 animation-delay-4000"
        >
        </div>

        <img
          transition:name="hero"
          transition:animate="fade"
          src="Myself.jpeg"
          alt="An image of Anindo Neel Dutta"
          class="z-10 max-w-xs md:max-w-sm md:rounded-full rounded-lg shadow-2xl md:mt-0 mt-10 border-0 md:border-t-2 md:border-b-2 border-cyan-500"
        />
      </div>
    </div>
  </div>
</section>

<style lang="scss" is:global>
  .hero-text {
    font-size: 6rem;
  }

  .hero-img {
    border-radius: 50%;
  }

  // make the class above responsive
  @media (max-width: 768px) {
    .hero-text {
      font-size: 4rem;
    }
  }

  // make me an animation where the blob moves around
  @keyframes blob {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }

  @keyframes blob2 {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(50px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-30px, 20px) scale(0.9);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }

  @keyframes blob3 {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(30px, -80px) scale(1.2);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.8);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }

  // make me another one but a little but different
  @keyframes blob4 {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(50px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-30px, 20px) scale(0.9);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }

  // now implement it in a class
  .animate-blob {
    animation: blob 7s infinite;
  }

  .animate-blob2 {
    animation: blob2 5s infinite;
  }

  .animate-blob3 {
    animation: blob3 8s infinite;
  }

  .animate-blob4 {
    animation: blob4 9s infinite;
  }
</style>

---
import Skill from "components/Skill.astro";
import skills from "data/skills.json";
---

<section class="md:px-[10rem] p-5 md:p-0">
  <h2 class="group text-2xl md:text-5xl font-bold mb-4">Technolgies I love</h2>

  <ul class="grid grid-cols-2 gap-4 sm:grid-cols-2">
    {skills.map((skill) => <Skill name={skill.name} icon={skill.icon} />)}
  </ul>
</section>

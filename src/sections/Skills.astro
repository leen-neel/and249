---
import Skill from "components/Skill.astro";
import skills from "data/skills";
---

<section class="md:px-[10rem] p-5 md:p-0 md:mb-10">
  <h2 class="group text-3xl md:text-5xl font-bold mb-4">Technolgies I love</h2>

  <ul class="grid grid-cols-2 gap-4 sm:grid-cols-2 mb-4">
    {skills.map((skill) => <Skill name={skill.name} icon={skill.icon} />)}
  </ul>
  <p class="font-bold">....and many more</p>
</section>
